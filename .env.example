# ==============================================================
# Calculadora de Prazos — Variáveis de Ambiente
# ==============================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env.local
#   2. Preencha com suas credenciais do Supabase
#   3. NUNCA commite o arquivo .env.local
#
# Para deploy na Vercel: configure estas variáveis em
#   Project Settings → Environment Variables
# ==============================================================

# --------------------------------------------------------------
# SUPABASE — Credenciais do projeto
# Encontre em: Supabase Dashboard → Project Settings → API
# --------------------------------------------------------------

# URL pública do projeto (seguro expor ao browser — identifica o projeto)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave anon/publishable (seguro expor ao browser — protegida pelo RLS do Supabase)
# ATENÇÃO: use APENAS a chave "anon" ou "publishable". NUNCA use a service_role key aqui.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------------------------
# NOTA DE SEGURANÇA:
# As variáveis NEXT_PUBLIC_* são intencionalmente expostas ao
# navegador. A segurança dos dados é garantida pelas políticas
# de Row Level Security (RLS) configuradas no Supabase.
#
# A chave "service_role" (admin) NUNCA deve ser usada aqui.
# Se precisar de operações admin, use uma API Route server-side
# com a variável sem o prefixo NEXT_PUBLIC_.
# --------------------------------------------------------------
